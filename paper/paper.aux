\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Leave-one-\(G_0\)-out log-space \(R^2\) per held-out fold for all evaluated models, on the same native \(128^3\) cells. ``+S'' appends the 45 multi-scale spatial features (Section~\ref {sec:spatial}); ``+W'' uses density-weighted training (Section~\ref {sec:weighting}). Stack rows give the Ridge-stacked ensemble of the indicated base pair, raw and with the two bias calibrations of Section~\ref {sec:ensemble}. The best value in each column is bold. Tabular rows are from the master comparison log; the U-Net row is its best configuration (32 base channels, 150 epochs, no dropout) trained at native \(128^3\). The final row, set off by a rule, is the deployed fully nested pipeline of Section~\ref {sec:per_fold}; it is excluded from the per-column bolding, which compares rows under the shared CV-OOF stacking protocol of Section~\ref {sec:ensemble}.}}{8}{table.2}\protected@file@percent }
\newlabel{tab:main}{{2}{8}{Leave-one-\(\Gzero \)-out log-space \(\Rsq \) per held-out fold for all evaluated models, on the same native \(128^3\) cells. ``+S'' appends the 45 multi-scale spatial features (Section~\ref {sec:spatial}); ``+W'' uses density-weighted training (Section~\ref {sec:weighting}). Stack rows give the Ridge-stacked ensemble of the indicated base pair, raw and with the two bias calibrations of Section~\ref {sec:ensemble}. The best value in each column is bold. Tabular rows are from the master comparison log; the U-Net row is its best configuration (32 base channels, 150 epochs, no dropout) trained at native \(128^3\). The final row, set off by a rule, is the deployed fully nested pipeline of Section~\ref {sec:per_fold}; it is excluded from the per-column bolding, which compares rows under the shared CV-OOF stacking protocol of Section~\ref {sec:ensemble}}{table.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Physical-field metrics for the models of Table~\ref {tab:main} (cross-fold means; mass ratio \(\mathcal  {M}\) as the min--max range over folds). RMSE decomposes as \(\mathrm  {RMSE}^2 = b^2 + s^2\) (equation~\ref {eq:rmse}); \(R^2_{\mathrm  {mol}}\)/\(R^2_{\mathrm  {dif}}\) are phase-conditional at \(\log _{10}(n_{\mathrm  {H_2}})= -4\); \(f_{0.1}\) is the fraction of cells within 0.1\,\text  {dex}; \(W_1\) the Wasserstein distance between marginals; skill is measured against the pointwise XGBoost row (equation~\ref {eq:skill}). \(^\dagger \)The U-Net's mass range is a lower bound on its violation (predictions clipped at truth \(+1\,\text  {dex}\); Section~\ref {sec:metrics}). The final row, set off by a rule, is the deployed fully nested pipeline of Section~\ref {sec:per_fold}, for which the clip is never active.}}{8}{table.3}\protected@file@percent }
\newlabel{tab:summary}{{3}{8}{Physical-field metrics for the models of Table~\ref {tab:main} (cross-fold means; mass ratio \(\Mratio \) as the min--max range over folds). RMSE decomposes as \(\mathrm {RMSE}^2 = b^2 + s^2\) (equation~\ref {eq:rmse}); \(\Rsq _{\mathrm {mol}}\)/\(\Rsq _{\mathrm {dif}}\) are phase-conditional at \(\logn = -4\); \(f_{0.1}\) is the fraction of cells within 0.1\dex ; \(W_1\) the Wasserstein distance between marginals; skill is measured against the pointwise XGBoost row (equation~\ref {eq:skill}). \(^\dagger \)The U-Net's mass range is a lower bound on its violation (predictions clipped at truth \(+1\dex \); Section~\ref {sec:metrics}). The final row, set off by a rule, is the deployed fully nested pipeline of Section~\ref {sec:per_fold}, for which the clip is never active}{table.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Ablation of the solver-derived self-shielding factor \(f_{\mathrm  {H_2}}\): key metrics with the full feature set (left of each arrow) and with \(f_{\mathrm  {H_2}}\) excluded from the local features and the spatial averages (right). \(R^2\) entries give mean \(\pm \) fold std.; RMSE and molecular-phase entries are cross-fold means. All runs use the identical pipeline, seeds, and hyperparameters; the without-\(f_{\mathrm  {H_2}}\) mass-calibrated stack keeps fold mass ratios of 0.93--1.16.}}{8}{table.4}\protected@file@percent }
\newlabel{tab:fh2}{{4}{8}{Ablation of the solver-derived self-shielding factor \(\fshield \): key metrics with the full feature set (left of each arrow) and with \(\fshield \) excluded from the local features and the spatial averages (right). \(\Rsq \) entries give mean \(\pm \) fold std.; RMSE and molecular-phase entries are cross-fold means. All runs use the identical pipeline, seeds, and hyperparameters; the without-\(\fshield \) mass-calibrated stack keeps fold mass ratios of 0.93--1.16}{table.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Per-fold behaviour of representative models across the \(G_0\) sweep: log-space \(R^2\) (\emph  {a}), RMSE (\emph  {b}), and skill against the pointwise XGBoost baseline (\emph  {c}). Grey bands mark the two extrapolation folds. The 3D U-Net (dotted) is the most accurate model on the interior folds and the least robust at both boundaries; the mass-calibrated weighted stack (purple) is the only model that remains strong across the entire range. XGBoost's decline with increasing \(G_0\) reflects constant-valued tree extrapolation in the \(\log G_0\) coordinate (Section~\ref {sec:cv}).}}{9}{figure.3}\protected@file@percent }
\newlabel{fig:modelcomp}{{3}{9}{Per-fold behaviour of representative models across the \(\Gzero \) sweep: log-space \(\Rsq \) (\emph {a}), RMSE (\emph {b}), and skill against the pointwise XGBoost baseline (\emph {c}). Grey bands mark the two extrapolation folds. The 3D U-Net (dotted) is the most accurate model on the interior folds and the least robust at both boundaries; the mass-calibrated weighted stack (purple) is the only model that remains strong across the entire range. XGBoost's decline with increasing \(\Gzero \) reflects constant-valued tree extrapolation in the \(\log \Gzero \) coordinate (Section~\ref {sec:cv})}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Mass budget and phase-conditional accuracy of the deployed (fully nested) pipeline of Section~\ref {sec:per_fold}. \emph  {(a)} Total H\(_2\) mass ratio per held-out fold: the raw stack (grey) over-predicts by \(\times \)1.65--1.90 at every \(G_0\); the mass-calibrated prediction (red) is within 9 per cent of the true mass in every fold. \emph  {(b)} Cell-mean log residual: the calibration also removes most of the mean bias. \emph  {(c)} Phase-conditional \(R^2\): molecular-phase accuracy is uniformly high (\(R^2\ge 0.98\)); the diffuse phase is hardest at low \(G_0\), where UV-exposed gas spans the steep transition.}}{9}{figure.4}\protected@file@percent }
\newlabel{fig:massbudget}{{4}{9}{Mass budget and phase-conditional accuracy of the deployed (fully nested) pipeline of Section~\ref {sec:per_fold}. \emph {(a)} Total H\(_2\) mass ratio per held-out fold: the raw stack (grey) over-predicts by \(\times \)1.65--1.90 at every \(\Gzero \); the mass-calibrated prediction (red) is within 9 per cent of the true mass in every fold. \emph {(b)} Cell-mean log residual: the calibration also removes most of the mean bias. \emph {(c)} Phase-conditional \(\Rsq \): molecular-phase accuracy is uniformly high (\(\Rsq \ge 0.98\)); the diffuse phase is hardest at low \(\Gzero \), where UV-exposed gas spans the steep transition}{figure.4}{}}
