\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces XGBoost gain importance, mean \(\pm \) std over the seven folds. \emph  {(a)} Pointwise model (15 local features): the solver-derived \(\log f_{\mathrm  {H_2}}\) dominates, followed by temperature and density. \emph  {(b)} Spatial-feature model, top 20 of 60 features (blue = local, red = neighbourhood means): \(f_{\mathrm  {H_2}}\) and its spatial averages fill the top ranks. \emph  {(c)} Importance aggregated per base field over all scales. Velocity and magnetic-field components are negligible in every view.}}{10}{figure.5}\protected@file@percent }
\newlabel{fig:importance}{{5}{10}{XGBoost gain importance, mean \(\pm \) std over the seven folds. \emph {(a)} Pointwise model (15 local features): the solver-derived \(\log \fshield \) dominates, followed by temperature and density. \emph {(b)} Spatial-feature model, top 20 of 60 features (blue = local, red = neighbourhood means): \(\fshield \) and its spatial averages fill the top ranks. \emph {(c)} Importance aggregated per base field over all scales. Velocity and magnetic-field components are negligible in every view}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Predicted versus true \(\log _{10}(n_{\mathrm  {H_2}})\) per held-out fold (two-dimensional histograms, log colour scale; dashed line = identity), for the deployed mass-calibrated pipeline. Per-fold \(R^2\), Pearson \(r\), and bias are annotated. The bimodal target structure is reproduced in every fold; scatter is dominated by the diffuse UV-exposed population.}}{10}{figure.6}\protected@file@percent }
\newlabel{fig:scatter}{{6}{10}{Predicted versus true \(\logn \) per held-out fold (two-dimensional histograms, log colour scale; dashed line = identity), for the deployed mass-calibrated pipeline. Per-fold \(\Rsq \), Pearson \(r\), and bias are annotated. The bimodal target structure is reproduced in every fold; scatter is dominated by the diffuse UV-exposed population}{figure.6}{}}
