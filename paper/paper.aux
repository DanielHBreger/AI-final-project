\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Leave-one-$G_0$-out log-space $R^2$ for all evaluated models on the full feature set. ``Feat.'' gives the input dimension (15 local; 60 = 15 local + 45 spatial; vol. = volumetric input at $64^3$). The best result in each column is bold. Tabular results are from the master comparison run (Section~\ref {sec:repro}); the 3D U-Net row is its best training configuration (32 base channels, 150 epochs, no dropout). The U-Net operates on $2\times $ downsampled volumes, so its comparison to the tabular rows is not at equal resolution.}}{6}{table.2}\protected@file@percent }
\newlabel{tab:main}{{2}{6}{Leave-one-$\Gzero $-out log-space $\Rsq $ for all evaluated models on the full feature set. ``Feat.'' gives the input dimension (15 local; 60 = 15 local + 45 spatial; vol. = volumetric input at $64^3$). The best result in each column is bold. Tabular results are from the master comparison run (Section~\ref {sec:repro}); the 3D U-Net row is its best training configuration (32 base channels, 150 epochs, no dropout). The U-Net operates on $2\times $ downsampled volumes, so its comparison to the tabular rows is not at equal resolution}{table.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Ablation of the solver-derived self-shielding factor $f_{\mathrm  {H_2}}$. Each cell gives the mean $\pm $ fold std.\ of log-space $R^2$ over the seven leave-one-$G_0$-out folds. ``With'' rows use all 15 local features (60 with spatial); ``without'' rows exclude $f_{\mathrm  {H_2}}$ from the local features and from the spatial averages (14 local; 56 with spatial). All runs use the identical pipeline, seeds, and hyperparameters.}}{6}{table.3}\protected@file@percent }
\newlabel{tab:fh2}{{3}{6}{Ablation of the solver-derived self-shielding factor $\fshield $. Each cell gives the mean $\pm $ fold std.\ of log-space $\Rsq $ over the seven leave-one-$\Gzero $-out folds. ``With'' rows use all 15 local features (60 with spatial); ``without'' rows exclude $\fshield $ from the local features and from the spatial averages (14 local; 56 with spatial). All runs use the identical pipeline, seeds, and hyperparameters}{table.3}{}}
