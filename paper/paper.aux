\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Summary of the final-model prediction run. \emph  {(a)} Log-space $R^2$ per held-out fold; the upward extrapolation fold $G_0= 6.4$ is the hardest for this model, followed by $G_0= 0.8$; the dashed line marks the seven-fold mean. \emph  {(b)} Clipped linear-space $R^2$ (secondary metric; Section~\ref {sec:metrics}); the much lower values reflect the dominance of the densest cells in linear space. \emph  {(c)} Fraction of cells with absolute residual below 0.1\,\text  {dex}, highest at low $G_0$ where the well-predicted shielded population is largest.}}{7}{figure.3}\protected@file@percent }
\newlabel{fig:summary}{{3}{7}{Summary of the final-model prediction run. \emph {(a)} Log-space $\Rsq $ per held-out fold; the upward extrapolation fold $\Gzero = 6.4$ is the hardest for this model, followed by $\Gzero = 0.8$; the dashed line marks the seven-fold mean. \emph {(b)} Clipped linear-space $\Rsq $ (secondary metric; Section~\ref {sec:metrics}); the much lower values reflect the dominance of the densest cells in linear space. \emph {(c)} Fraction of cells with absolute residual below 0.1\dex , highest at low $\Gzero $ where the well-predicted shielded population is largest}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Predicted versus true $\log _{10}(n_{\mathrm  {H_2}})$ per held-out fold (two-dimensional histograms, log colour scale; dashed line = identity). Per-fold $R^2$, RMSE, and MAE are annotated. The bimodal target structure is reproduced in every fold; scatter is dominated by the diffuse UV-exposed population.}}{7}{figure.4}\protected@file@percent }
\newlabel{fig:scatter}{{4}{7}{Predicted versus true $\logn $ per held-out fold (two-dimensional histograms, log colour scale; dashed line = identity). Per-fold $\Rsq $, RMSE, and MAE are annotated. The bimodal target structure is reproduced in every fold; scatter is dominated by the diffuse UV-exposed population}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Residual distributions (predicted $-$ true, dex) per fold, with best-fit normal curves and their $(\mu , \sigma )$ annotated. Distribution widths decrease monotonically with $G_0$. Note the systematic positive bias at the interior folds (up to $+0.5\,\text  {dex}$ at $G_0= 0.8$) and the multi-modal structure at several folds: the Gaussian curves summarise location and scale only and should not be read as a claim of normality.}}{8}{figure.5}\protected@file@percent }
\newlabel{fig:residuals}{{5}{8}{Residual distributions (predicted $-$ true, dex) per fold, with best-fit normal curves and their $(\mu , \sigma )$ annotated. Distribution widths decrease monotonically with $\Gzero $. Note the systematic positive bias at the interior folds (up to $+0.5\dex $ at $\Gzero = 0.8$) and the multi-modal structure at several folds: the Gaussian curves summarise location and scale only and should not be read as a claim of normality}{figure.5}{}}
