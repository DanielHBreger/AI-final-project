\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Single-cube transfer: log-space $R^2$ for models trained on one cube (rows) and evaluated on each cube (columns), for XGBoost (\emph  {left}), MLP (\emph  {centre}), and the stacked ensemble (\emph  {right}). Diagonal cells are in-sample fits. Transfer quality decays with $G_0$ separation; values for separations of four or more geometric steps are poor and can be strongly negative.}}{12}{figure.9}\protected@file@percent }
\newlabel{fig:heatmap}{{9}{12}{Single-cube transfer: log-space $\Rsq $ for models trained on one cube (rows) and evaluated on each cube (columns), for XGBoost (\emph {left}), MLP (\emph {centre}), and the stacked ensemble (\emph {right}). Diagonal cells are in-sample fits. Transfer quality decays with $\Gzero $ separation; values for separations of four or more geometric steps are poor and can be strongly negative}{figure.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Within-cube sampling geometry: test $R^2$ per training geometry (columns) and cube (rows) for XGBoost (\emph  {left}), MLP (\emph  {centre}), and the stacked ensemble (\emph  {right}). Random coverage $\geq $5--10 per cent reconstructs the held-out cells well in every cube; 50 per cent contiguous slabs fail in every cube; compact boxes are intermediate; 1 per cent random coverage is unstable, varying from $R^2\approx 0.9$ to strongly negative between cubes.}}{12}{figure.10}\protected@file@percent }
\newlabel{fig:intra_cube}{{10}{12}{Within-cube sampling geometry: test $\Rsq $ per training geometry (columns) and cube (rows) for XGBoost (\emph {left}), MLP (\emph {centre}), and the stacked ensemble (\emph {right}). Random coverage $\geq $5--10 per cent reconstructs the held-out cells well in every cube; 50 per cent contiguous slabs fail in every cube; compact boxes are intermediate; 1 per cent random coverage is unstable, varying from $\Rsq \approx 0.9$ to strongly negative between cubes}{figure.10}{}}
