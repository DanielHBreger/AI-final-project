\newlabel{fig:spatial}{{10}{14}{Mid-plane (\(z = 64\)) slices of the \(\logn \) field for each \(\Gzero \) (rows): ground truth, prediction, and absolute error (columns), for the deployed pipeline. Truth and prediction share one colour scale per row; the error column has its own scale. Residuals trace the boundaries of shielded filaments at low \(\Gzero \); at high \(\Gzero \) the field is nearly uniform}{figure.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Single-cube transfer: log-space \(R^2\) for models trained on one cube (rows) and evaluated on each cube (columns), for XGBoost (\emph  {left}), MLP (\emph  {centre}), and the stacked ensemble (\emph  {right}). Diagonal cells are in-sample fits. Transfer quality decays with \(G_0\) separation; values for separations of four or more geometric steps are poor and can be strongly negative.}}{15}{figure.11}\protected@file@percent }
\newlabel{fig:heatmap}{{11}{15}{Single-cube transfer: log-space \(\Rsq \) for models trained on one cube (rows) and evaluated on each cube (columns), for XGBoost (\emph {left}), MLP (\emph {centre}), and the stacked ensemble (\emph {right}). Diagonal cells are in-sample fits. Transfer quality decays with \(\Gzero \) separation; values for separations of four or more geometric steps are poor and can be strongly negative}{figure.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces Within-cube sampling geometry: test \(R^2\) per training geometry (columns) and cube (rows) for XGBoost (\emph  {left}), MLP (\emph  {centre}), and the stacked ensemble (\emph  {right}). Random coverage \(\geq \)5 per cent reconstructs the held-out cells to \(R^2\geq 0.97\) in every cube; contiguous half-cube slabs and small compact boxes are systematically worse despite far larger volume (down to \(R^2\approx 0.4\)--0.6 in the worst cubes). The MLP alone can fail strongly on contiguous geometries; the stacked ensemble follows the more robust XGBoost.}}{15}{figure.12}\protected@file@percent }
\newlabel{fig:intra_cube}{{12}{15}{Within-cube sampling geometry: test \(\Rsq \) per training geometry (columns) and cube (rows) for XGBoost (\emph {left}), MLP (\emph {centre}), and the stacked ensemble (\emph {right}). Random coverage \(\geq \)5 per cent reconstructs the held-out cells to \(\Rsq \geq 0.97\) in every cube; contiguous half-cube slabs and small compact boxes are systematically worse despite far larger volume (down to \(\Rsq \approx 0.4\)--0.6 in the worst cubes). The MLP alone can fail strongly on contiguous geometries; the stacked ensemble follows the more robust XGBoost}{figure.12}{}}
