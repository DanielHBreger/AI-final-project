\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Progressive improvement in mean leave-one-$G_0$-out $R^2$ at each step of the ablation. Bars show the mean; whiskers indicate $\pm 1\sigma $ across folds; filled and open dots show individual fold $R^2$ values (open dots: extrapolation folds $G_0= 0.1$ and $G_0= 0.2$). The $3^3$ spatial step contributes the largest single-step gain (+0.030), exceeding the combined effect of all subsequent steps.}}{5}{figure.3}\protected@file@percent }
\newlabel{fig:ablation}{{3}{5}{Progressive improvement in mean leave-one-$\Gzero $-out $\Rsq $ at each step of the ablation. Bars show the mean; whiskers indicate $\pm 1\sigma $ across folds; filled and open dots show individual fold $\Rsq $ values (open dots: extrapolation folds $\Gzero = 0.1$ and $\Gzero = 0.2$). The $3^3$ spatial step contributes the largest single-step gain (+0.030), exceeding the combined effect of all subsequent steps}{figure.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Leave-one-$G_0$-out performance (log-space $R^2$) for all evaluated configurations. The best result in each column is bold. The 3D U-Net results represent the best-performing size variant (\textsc  {unet\_standard}, 5.8\,M parameters, 150 epochs, no dropout) for each fold where a result was obtained; missing entries indicate runs that were not completed for that fold variant. The linear regression results are shown for context; negative $R^2$ values indicate performance worse than predicting the fold mean.}}{6}{table.2}\protected@file@percent }
\newlabel{tab:full}{{2}{6}{Leave-one-$\Gzero $-out performance (log-space $\Rsq $) for all evaluated configurations. The best result in each column is bold. The 3D U-Net results represent the best-performing size variant (\textsc {unet\_standard}, 5.8\,M parameters, 150 epochs, no dropout) for each fold where a result was obtained; missing entries indicate runs that were not completed for that fold variant. The linear regression results are shown for context; negative $\Rsq $ values indicate performance worse than predicting the fold mean}{table.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Three-panel summary of the final model (\textsc  {ens\_sp}) performance. \emph  {(a)} Log-space $R^2$ per held-out fold. The two extrapolation folds ($G_0= 0.1$ and $G_0= 6.4$) are the most challenging; the dashed line marks the seven-fold mean. \emph  {(b)} Secondary clipped linear-space $R^2$ with predictions constrained to $\pm 1\,\text  {dex}$ of the true range before exponentiation; the substantially lower values illustrate the difficulty of linear-space density prediction over the full dynamic range. \emph  {(c)} Fraction of cells with absolute log-space residual below 0.1\,\text  {dex}. The concentration of accurate cells in mid-range folds indicates that the low-$G_0$ self-shielding-dominated regime is the most difficult to emulate accurately.}}{6}{figure.4}\protected@file@percent }
\newlabel{fig:summary}{{4}{6}{Three-panel summary of the final model (\enssp ) performance. \emph {(a)} Log-space $\Rsq $ per held-out fold. The two extrapolation folds ($\Gzero = 0.1$ and $\Gzero = 6.4$) are the most challenging; the dashed line marks the seven-fold mean. \emph {(b)} Secondary clipped linear-space $\Rsq $ with predictions constrained to $\pm 1\dex $ of the true range before exponentiation; the substantially lower values illustrate the difficulty of linear-space density prediction over the full dynamic range. \emph {(c)} Fraction of cells with absolute log-space residual below 0.1\dex . The concentration of accurate cells in mid-range folds indicates that the low-$\Gzero $ self-shielding-dominated regime is the most difficult to emulate accurately}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Predicted versus true $\log _{10}(n_{\mathrm  {H_2}})$ for all seven held-out folds. Each panel is a two-dimensional histogram with colour encoding point density on a logarithmic scale; the dashed line marks perfect prediction. Per-fold $R^2$, RMSE (dex), and MAE (dex) are annotated in each panel. Scatter is widest at the two extrapolation folds ($G_0= 0.1$ and $G_0= 0.2$) and tightest at the mid-range interpolation folds ($G_0= 0.8$--3.2).}}{6}{figure.5}\protected@file@percent }
\newlabel{fig:scatter}{{5}{6}{Predicted versus true $\logn $ for all seven held-out folds. Each panel is a two-dimensional histogram with colour encoding point density on a logarithmic scale; the dashed line marks perfect prediction. Per-fold $\Rsq $, RMSE (dex), and MAE (dex) are annotated in each panel. Scatter is widest at the two extrapolation folds ($\Gzero = 0.1$ and $\Gzero = 0.2$) and tightest at the mid-range interpolation folds ($\Gzero = 0.8$--3.2)}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Residual distributions (prediction $-$ truth, in dex) for all seven held-out folds. Histograms show the empirical distribution; curves show the best-fit normal $\mathcal  {N}(\mu , \sigma )$ with parameters annotated. The distributions are approximately Gaussian and near-zero centred in all folds; the width decreases from the boundary folds ($G_0= 0.1$ and $G_0= 0.2$) to the interior folds ($G_0= 1.6$--3.2).}}{7}{figure.6}\protected@file@percent }
\newlabel{fig:residuals}{{6}{7}{Residual distributions (prediction $-$ truth, in dex) for all seven held-out folds. Histograms show the empirical distribution; curves show the best-fit normal $\mathcal {N}(\mu , \sigma )$ with parameters annotated. The distributions are approximately Gaussian and near-zero centred in all folds; the width decreases from the boundary folds ($\Gzero = 0.1$ and $\Gzero = 0.2$) to the interior folds ($\Gzero = 1.6$--3.2)}{figure.6}{}}
